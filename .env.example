# Provider AI e modello
PROVIDER=anthropic
MODEL=claude-haiku-4-5-20251001

# API key del provider (obbligatoria)
ANTHROPIC_API_KEY=sk-ant-...

# Ricerca web via Serper (opzionale — senza questa usa DuckDuckGo)
SERPER_API_KEY=

# Porta del server API
PORT=3001

# Prompt di sistema dell'agente
SYSTEM_PROMPT=Sei un assistente utile e conciso. Rispondi sempre in italiano.

# Google Workspace OAuth (solo se abilitato durante lo scaffold)
# Ottieni Client ID e Secret da Google Cloud Console → Credenziali → OAuth 2.0
# Poi esegui: node setup.js
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
